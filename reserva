    function getSquareClass(property) {
        if (property.group === 'special') {
            const specialMap = {
                start: 'sq-corner',
                tax: 'sq-tax',
                jail: 'sq-jail',
                parking: 'sq-parking',
                gotojail: 'sq-gotojail',
                chance: 'sq-chance'
            };
            return specialMap[property.type] || 'sq-chance';
        }
        
        const colorMap = {
            brown: 'sq-brown',
            lightblue: 'sq-lightblue',
            pink: 'sq-pink',
            orange: 'sq-orange',
            red: 'sq-red',
            yellow: 'sq-yellow',
            green: 'sq-green',
            darkblue: 'sq-darkblue',
            railroad: 'sq-railroad',
            utility: 'sq-utility'
        };
        
        return colorMap[property.group] || '';
    }

    function updateBoard() {
        const board = document.getElementById('board');
        board.innerHTML = '';

        const playerPositions = {};
        gameState.players.forEach(p => {
            if (!playerPositions[p.position]) playerPositions[p.position] = [];
            playerPositions[p.position].push(p);
        });

        for (let i = 0; i < BOARD_SIZE; i++) {
            const property = PROPERTIES[i];
            const sq = document.createElement('div');
            sq.className = 'square ' + getSquareClass(property);
            sq.setAttribute('data-property-id', property.id);

            const isCurrentPosition = gameState.players.some(p => p.position === i && p.id === gameState.currentPlayerIndex);
            if (isCurrentPosition) sq.classList.add('current-position');

            // Posicionar no grid
            let row, col;
            if (i === 0) { row = 11; col = 11; }
            else if (i < 10) { row = 11; col = 11 - i; }
            else if (i === 10) { row = 11; col = 1; }
            else if (i < 20) { row = 21 - i; col = 1; }
            else if (i === 20) { row = 1; col = 1; }
            else if (i < 30) { row = 1; col = i - 19; }
            else if (i === 30) { row = 1; col = 11; }
            else { row = i - 29; col = 11; }

            sq.style.gridColumn = col;
            sq.style.gridRow = row;

            let html = '';

            // Barra de cor para propriedades
            if (property.group !== 'special' && property.type === 'property') {
                html += `<div class="square-color-bar" style="background:${property.color};"></div>`;
            }

            // Nome da propriedade
            html += `<div class="square-name">${property.name}</div>`;

            // Preço
            if (property.price > 0) {
                html += `<div class="square-price">$${property.price}</div>`;
            }

            // Casas/hotéis
            if (property.type === 'property') {
                const houses = gameState.propertyHouses[i] || 0;
                if (houses > 0) {
                    html += `<div class="square-houses">`;
                    if (houses < 5) {
                        for (let h = 0; h < houses; h++) html += `<div class="house-icon"></div>`;
                    } else {
                        html += `<div class="hotel-icon"></div>`;
                    }
                    html += `</div>`;
                }
            }

            // Barra de dono
            const ownerId = gameState.propertyOwners[i];
            if (ownerId !== undefined) {
                html += `<div class="owner-bar ${PLAYER_COLORS[ownerId]}"></div>`;
            }

            // Indicador de hipoteca
            if (mortgageState.mortgagedProperties[i]) {
                html += `<div class="mortgage-indicator">💰</div>`;
            }
            
            // Tokens dos jogadores
            html += `<div class="player-tokens">`;
            if (playerPositions[i]) {
                playerPositions[i].forEach(p => {
                    const isCurrent = p.id === gameState.currentPlayerIndex;
                    html += `<div class="player-token ${PLAYER_COLORS[p.id]} ${isCurrent ? 'current' : ''}" title="${p.name}">${PLAYER_NUMS[p.id]}</div>`;
                });
            }
            html += `</div>`;

            sq.innerHTML = html;
            board.appendChild(sq);
        }
    }

