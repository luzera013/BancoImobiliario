    function rollDice() {
        const player = getCurrentPlayer();
        if (gameState.diceValue !== 0) return;

        soundManager.play('dice');
        gameState.stats.totalRolls++;

        const d1 = Math.floor(Math.random() * 6) + 1;
        const d2 = Math.floor(Math.random() * 6) + 1;
        gameState.dice1 = d1;
        gameState.dice2 = d2;
        gameState.diceValue = d1 + d2;

        // Animação dos dados
        const dice1El = document.getElementById('dice1');
        const dice2El = document.getElementById('dice2');
        dice1El.classList.add('rolling');
        dice2El.classList.add('rolling');
        
        setTimeout(() => {
            dice1El.classList.remove('rolling');
            dice2El.classList.remove('rolling');
            dice1El.textContent = d1;
            dice2El.textContent = d2;
            document.getElementById('diceTotal').textContent = d1 + d2;
        }, 400);

        // Mover jogador
        let oldPos = player.position;
        player.position = (player.position + gameState.diceValue) % BOARD_SIZE;

        // Passar pela saída
        if (oldPos + gameState.diceValue >= BOARD_SIZE) {
            player.money += 200;
            gameState.stats.totalMoneyEarned += 200;
            soundManager.play('passGo');
        }

        // Processar casa onde parou
        setTimeout(() => {
            handleLandedOnProperty();
            updateUI();
        }, 800);
    }

    function handleLandedOnProperty() {
        const player = getCurrentPlayer();
        const property = PROPERTIES[player.position];

        if (property.type === 'tax') {
            const tax = Math.abs(property.price);
            player.money -= tax;
            gameState.stats.totalMoneySpent += tax;
            soundManager.play('moneyLoss');
            
            // Criar animação de dinheiro negativo
            createMoneyAnimation(`-$${tax}`, true);
            
            addLog(`${player.name} pagou imposto: -$${tax}`, 'warning');
            showNotification('Imposto!', `-$${tax}`, 'warning');
            checkPlayerBankrupt();
        } else if (property.type === 'chance') {
            soundManager.play('chance');
            const events = [
                { money: 50, title: 'Boa sorte!', msg: '+$50 encontrados' },
                { money: -50, title: 'Má sorte!', msg: '-$50 de multa' },
                { money: 100, title: 'Prêmio!', msg: '+$100 recebidos' },
                { money: -100, title: 'Despesa!', msg: '-$100 pagos' }
            ];
            const ev = events[Math.floor(Math.random() * events.length)];
            player.money += ev.money;
            soundManager.play(ev.money > 0 ? 'moneyGain' : 'moneyLoss');
            addLog(`${player.name} sorte: ${ev.msg}`, 'warning');
            showNotification(ev.title, ev.msg, ev.money > 0 ? 'success' : 'warning');
            checkPlayerBankrupt();
        } else if (property.type === 'gotojail') {
            player.position = 10;
            player.inJail = true;
            player.jailTurns = 3;
            soundManager.play('jail');
            addLog(`${player.name} foi para o PRESÍDIO!`, 'error');
            showNotification('Presídio!', `${player.name} ficará preso`, 'error');
        } else if (property.type === 'railroad' || property.type === 'utility') {
            const owner = gameState.propertyOwners[property.id];
            if (owner !== undefined && owner !== player.id) {
                const ownerPlayer = gameState.players[owner];
                const rent = property.type === 'railroad' ? 50 : 100;
                player.money -= rent;
                ownerPlayer.money += rent;
                soundManager.play('moneyLoss');
                addLog(`${player.name} pagou aluguel $${rent} para ${ownerPlayer.name}`, 'warning');
                showNotification('Aluguel pago!', `-$${rent} para ${ownerPlayer.name}`, 'warning');
                checkPlayerBankrupt();
            }
        } else if (property.type === 'property') {
            const owner = gameState.propertyOwners[property.id];
            if (owner !== undefined && owner !== player.id) {
                const ownerPlayer = gameState.players[owner];
                const houses = gameState.propertyHouses[property.id] || 0;
                let rent = 0;
                if (houses === 0) rent = Math.ceil(property.price * 0.1);
                else if (houses < 4) rent = Math.ceil(property.price * (0.2 + houses * 0.2));
                else if (houses === 4) rent = Math.ceil(property.price * 0.9);
                else rent = property.price * 2;

                player.money -= rent;
                ownerPlayer.money += rent;
                soundManager.play('moneyLoss');
                addLog(`${player.name} pagou aluguel $${rent} para ${ownerPlayer.name}`, 'warning');
                showNotification('Aluguel pago!', `-$${rent} para ${ownerPlayer.name}`, 'warning');
                checkPlayerBankrupt();
            } else if (owner === undefined) {
                addLog(`${player.name} caiu em ${property.name} (livre)`, 'info');
                gameState.selectedProperty = property;
                document.getElementById('buyBtn').disabled = false;
                
                // Mostrar diálogo automaticamente para humanos
                if (player.type === 'human') {
                    setTimeout(() => buyProperty(), 500);
                }
            }
        }
    }

