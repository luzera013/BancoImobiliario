        const property = gameState.selectedProperty;
        document.getElementById('propertyDialog').classList.remove('show');
        gameState.selectedProperty = null;
        document.getElementById('buyBtn').disabled = true;
        
        // Iniciar leilão se a propriedade não foi comprada
