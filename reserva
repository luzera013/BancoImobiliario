    function requestBankLoan(amount) {
        const player = getCurrentPlayer();
        const maxLoan = Math.floor(player.money * 2);
        
        if (amount > maxLoan) {
            showNotification('Valor muito alto!', `O valor máximo é $${maxLoan}`, 'error');
            return;
        }
        
        if (mortgageState.bankLoans[player.id]) {
            showNotification('Empréstimo ativo!', 'Você já tem um empréstimo em andamento', 'error');
            return;
        }
        
        // Conceder empréstimo
        player.money += amount;
        mortgageState.bankLoans[player.id] = {
            amount: amount,
            interestRate: 0.1, // 10% por turno
            turnsLeft: 10,
            startTurn: gameState.round
        };
        
        addLog(`🏦 ${player.name} pegou um empréstimo de $${amount} (10% de juros)`, 'action');
        showNotification('Empréstimo Aprovado!', `Você recebeu $${amount}`, 'success');
        soundManager.play('moneyGain');
        
        showBankDialog(); // Atualizar diálogo
        updateUI();
        SaveManager.autoSave();
    }

    function repayBankLoan() {
        const player = getCurrentPlayer();
        const loan = mortgageState.bankLoans[player.id];
        
        if (!loan) {
            showNotification('Sem empréstimo!', 'Você não tem empréstimos ativos', 'warning');
            return;
        }
        
        const totalOwed = loan.amount + Math.floor(loan.amount * loan.interestRate * loan.turnsLeft);
        
        if (player.money < totalOwed) {
            showNotification('Saldo insuficiente!', `Você precisa de $${totalOwed} para pagar o empréstimo`, 'error');
            return;
        }
        
        // Pagar empréstimo
        player.money -= totalOwed;
        delete mortgageState.bankLoans[player.id];
        
        addLog(`🏦 ${player.name} pagou seu empréstimo de $${totalOwed}`, 'action');
        showNotification('Empréstimo Pago!', `Você quitou sua dívida de $${totalOwed}`, 'success');
        soundManager.play('moneyLoss');
        
        showBankDialog(); // Atualizar diálogo
        updateUI();
        SaveManager.autoSave();
    }

    function processBankLoans() {
        // Processar juros e pagamentos de empréstimos a cada turno
        gameState.players.forEach(player => {
            const loan = mortgageState.bankLoans[player.id];
            if (loan) {
                loan.turnsLeft--;
                
                if (loan.turnsLeft <= 0) {
                    // Empréstimo venceu - cobrar forçadamente
                    const totalOwed = loan.amount + Math.floor(loan.amount * loan.interestRate * 10);
                    player.money = Math.max(0, player.money - totalOwed);
                    
                    addLog(`🏦 ${player.name} teve seu empréstimo vencido! $${totalOwed} deduzidos`, 'error');
                    showNotification('Empréstimo Vencido!', `${player.name} - $${totalOwed}`, 'error');
                    
                    delete mortgageState.bankLoans[player.id];
                } else if (loan.turnsLeft <= 3) {
                    // Avisar sobre empréstimo próximo do vencimento
                    addLog(`⚠️ ${player.name}: seu empréstimo vence em ${loan.turnsLeft} turnos!`, 'warning');
                }
            }
        });
    }

