    function aiShouldAcceptTrade(trade) {
        const difficulty = AI_DIFFICULTY[AI_DIFFICULTY_LEVEL];
        const player = gameState.players[trade.target];
        
        // Calcular valor da oferta
        let offerValue = trade.offer.money;
        trade.offer.properties.forEach(propId => {
            const prop = PROPERTIES[propId];
            offerValue += prop.price;
        });
        
        // Calcular valor da solicitação
        let requestValue = trade.request.money;
        trade.request.properties.forEach(propId => {
            const prop = PROPERTIES[propId];
            requestValue += prop.price;
        });
        
        // Lógica de decisão da IA
        const ratio = offerValue / requestValue;
        const shouldAccept = ratio > (1.2 - difficulty.tradeAggressiveness * 0.3);
        
        // Adicionar chance de erro
        if (Math.random() < difficulty.mistakeChance) {
            return !shouldAccept;
        }
        
        return shouldAccept;
    }

    function acceptTrade() {
        const initiator = gameState.players[tradeState.initiator];
        const target = gameState.players[tradeState.target];
        
        // Validar novamente antes de executar
        if (tradeState.offer.money > initiator.money) {
            showNotification('Falha na negociação!', 'O iniciador não tem dinheiro suficiente', 'error');
            closeTradeResponse();
            return;
        }
        
        if (tradeState.request.money > target.money) {
            showNotification('Falha na negociação!', 'O alvo não tem dinheiro suficiente', 'error');
            closeTradeResponse();
            return;
        }
        
        // Executar troca
        // Transferir dinheiro
        initiator.money -= tradeState.offer.money;
        initiator.money += tradeState.request.money;
        target.money -= tradeState.request.money;
        target.money += tradeState.offer.money;
        
        // Transferir propriedades
        tradeState.offer.properties.forEach(propId => {
            const index = initiator.properties.indexOf(propId);
            if (index > -1) {
                initiator.properties.splice(index, 1);
                target.properties.push(propId);
                gameState.propertyOwners[propId] = target.id;
            }
        });
        
        tradeState.request.properties.forEach(propId => {
            const index = target.properties.indexOf(propId);
            if (index > -1) {
                target.properties.splice(index, 1);
                initiator.properties.push(propId);
                gameState.propertyOwners[propId] = initiator.id;
            }
        });
        
        // Notificar
        addLog(`🤝 ${initiator.name} e ${target.name} fizeram uma negociação!`, 'action');
        showNotification('Negociação Aceita!', 'Troca realizada com sucesso', 'success');
        soundManager.play('buy');
        
        closeTradeResponse();
        updateUI();
        SaveManager.autoSave();
    }

