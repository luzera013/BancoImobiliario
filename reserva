    function confirmBuy() {
        const player = getCurrentPlayer();
        const property = gameState.selectedProperty;
        
        if (player.money >= property.price) {
            player.money -= property.price;
            player.properties.push(property.id);
            gameState.propertyOwners[property.id] = player.id;
            gameState.stats.totalMoneySpent += property.price;
            gameState.stats.propertiesBought++;
