    function enableTurboMode() {
        // Dobrar recompensas de XP
        Object.keys(XP_REWARDS).forEach(key => {
            XP_REWARDS[key] *= 2;
        });
        
        // Construção instantânea
        const originalBuildHouse = buildHouseOnProperty;
        buildHouseOnProperty = function(propId) {
            const player = getCurrentPlayer();
            const prop = PROPERTIES[propId];
            
            // Construir instantaneamente sem custo
            gameState.propertyHouses[propId] = (gameState.propertyHouses[propId] || 0) + 1;
            
            // XP dobrado
            addXP(player.id, XP_REWARDS.buildHouse * 2, `construção turbo em ${prop.name}`);
            
            addLog(`⚡️ ${player.name} construiu instantaneamente em ${prop.name}!`, 'success');
            showNotification('Construção Turbo!', `${prop.name} - Grátis!`, 'success');
            soundManager.play('build');
            
            declineBuild();
            updateUI();
        };
        
        // Movimento 2x mais rápido
        const originalRollDice = rollDice;
        rollDice = function() {
            originalRollDice();
            // Dobra o movimento
            if (gameState.diceValue > 0) {
                gameState.diceValue *= 2;
                movePlayer(getCurrentPlayer(), gameState.diceValue);
            }
        };
        
        addLog('⚡️ MODO TURBO ATIVADO! Velocidade 2x, recompensas dobradas!', 'success');
        showNotification('Modo Turbo!', 'Velocidade e recompensas dobradas!', 'success');
    }
    
