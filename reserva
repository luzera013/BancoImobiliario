            };
            
            localStorage.setItem('bancoImobiliarioSave', JSON.stringify(saveData));
            showNotification('Jogo Salvo!', 'Progresso salvo com sucesso', 'success');
        },
        
        load: function() {
            const saveData = localStorage.getItem('bancoImobiliarioSave');
            
            if (!saveData) {
                showNotification('Sem Save!', 'Nenhum jogo salvo encontrado', 'warning');
                return false;
            }
            
            try {
                const data = JSON.parse(saveData);
                
                // Restaurar estado do jogo
                Object.assign(gameState, data.gameState);
                Object.assign(playerXP, data.playerXP);
                Object.assign(playerStats, data.playerStats);
                Object.assign(globalStats, data.globalStats);
                
                // Restaurar economia virtual (versão 3.0+)
                if (data.virtualEconomy) {
                    Object.assign(VIRTUAL_ECONOMY, data.virtualEconomy);
                }
                
                // Carregar dados de personalização
                loadCustomizationData();
                
                // Atualizar interface
                updateUI();
                updateBoard();
                updateSidePanel();
                updatePlayersList();
                updateCustomizationUI();
                
                showNotification('Jogo Carregado!', 'Progresso restaurado com sucesso', 'success');
                return true;
            } catch (e) {
                showNotification('Erro ao Carregar!', 'Save corrompido ou inválido', 'error');
                console.error('Erro ao carregar save:', e);
                return false;
            }
        },
        
        autoSave: function() {
            if (!gameState.gameActive) return;
            
            // Salvar dados de personalização
            saveCustomizationData();
            
            const saveData = {
                gameState: gameState,
                playerXP: playerXP,
                playerStats: playerStats,
                globalStats: globalStats,
                virtualEconomy: VIRTUAL_ECONOMY,
                timestamp: Date.now(),
                version: '3.0'
            };
            
            localStorage.setItem('bancoImobiliarioAutoSave', JSON.stringify(saveData));
        },
        
        loadAutoSave: function() {
            const saveData = localStorage.getItem('bancoImobiliarioAutoSave');
            
