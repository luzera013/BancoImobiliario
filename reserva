                    <div class="achievement-info">
                        <div class="achievement-name">${achievement.name}</div>
                        <div class="achievement-desc">${achievement.desc}</div>
                        <div class="achievement-progress">
                            <div class="achievement-progress-bar" style="width: ${progress}%"></div>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    function getAchievementProgress(achievement, player) {
        if (achievementsState.unlocked.includes(achievement.id)) return 100;
        
        switch(achievement.id) {
            case 'first_property': return Math.min(100, (player.properties.length / 1) * 100);
            case 'property_mogul': return Math.min(100, (player.properties.length / 10) * 100);
            case 'house_builder': {
                const houses = Object.values(gameState.propertyHouses).reduce((sum, h) => sum + (h < 5 ? h : 0), 0);
                return Math.min(100, (houses / 5) * 100);
            }
            case 'hotel_tycoon': return Object.values(gameState.propertyHouses).some(h => h >= 5) ? 100 : 0;
            case 'rich_player': return Math.min(100, (player.money / 5000) * 100);
            case 'round_master': return Math.min(100, (gameState.round / 10) * 100);
            default: return 0;
        }
    }

    function checkAchievements() {
        const player = getCurrentPlayer();
        
        ACHIEVEMENTS.forEach(achievement => {
            if (!achievementsState.unlocked.includes(achievement.id)) {
                try {
                    if (achievement.condition(player)) {
                        unlockAchievement(achievement);
                    }
                } catch (e) {
                    // Ignorar erros em condições de conquista
                }
            }
        });
    }

    function unlockAchievement(achievement) {
        if (achievementsState.unlocked.includes(achievement.id)) return;
        
        achievementsState.unlocked.push(achievement.id);
        soundManager.play('achievement');
        
        // Adicionar animação de tabuleiro
        const board = document.getElementById('board');
        board.classList.add('shaking');
        setTimeout(() => board.classList.remove('shaking'), 500);
        
        showNotification(
            '🏆 Conquista Desbloqueada!',
            `${achievement.name} - ${achievement.desc}`,
            'success'
        );
        
        addLog(`🏆 ${achievement.name} desbloqueada!`, 'action');
        updateAchievements();
    }

