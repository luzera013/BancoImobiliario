                return gameState.propertyOwners[pr.id] === player.id;
            });
            if (owned.length === gp.length) {
                const pr = PROPERTIES.find(p => p.name === gp[0]);
                if ((gameState.propertyHouses[pr.id] || 0) < 5) { canBuild = true; break; }
            }
        }
        buildBtn.disabled = !canBuild;
        
        skipBtn.disabled = gameState.diceValue === 0;
        
        // Iniciar turno da IA automaticamente
