                setTimeout(() => this.playTone(880, 0.1, 'sine'), 100);
            };
            this.sounds.error = () => {
                this.playTone(165, 0.3, 'sawtooth');
                setTimeout(() => this.playTone(110, 0.2, 'sawtooth'), 150);
            };
