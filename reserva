    function startAuctionTimer() {
        if (auctionState.timer) {
            clearInterval(auctionState.timer);
        }
        
        auctionState.timer = setInterval(() => {
            auctionState.timeLeft--;
            document.getElementById('auctionTimer').textContent = `${auctionState.timeLeft}s`;
            
            // Mudar cor do timer quando estiver acabando
            const timerEl = document.getElementById('auctionTimer');
            if (auctionState.timeLeft <= 5) {
                timerEl.style.color = 'var(--danger)';
            } else if (auctionState.timeLeft <= 10) {
                timerEl.style.color = 'var(--warning)';
            }
            
            if (auctionState.timeLeft <= 0) {
                endAuction();
            }
        }, 1000);
    }

    function makeAuctionBid(amount) {
        const player = getCurrentPlayer();
        const newBid = auctionState.currentBid + amount;
        
        // Validar se o jogador tem dinheiro suficiente
        if (player.money < newBid) {
            showNotification('Saldo insuficiente!', `Você precisa de $${newBid} para fazer este lance`, 'error');
            return;
        }
        
        // Validar se o lance é maior que o atual
        if (newBid <= auctionState.currentBid) {
            showNotification('Lance inválido!', 'Seu lance deve ser maior que o lance atual', 'warning');
            return;
        }
        
        // Fazer o lance
        auctionState.currentBid = newBid;
        auctionState.currentBidder = player.id;
        auctionState.bids.push({
            playerId: player.id,
            playerName: player.name,
            amount: newBid,
            timestamp: Date.now()
        });
        
        // Resetar timer para 15 segundos quando há um novo lance
        auctionState.timeLeft = Math.max(auctionState.timeLeft, 15);
        
        // Atualizar interface
        document.getElementById('currentBid').textContent = `$${newBid}`;
        document.getElementById('auctionTimer').textContent = `${auctionState.timeLeft}s`;
        document.getElementById('auctionTimer').style.color = 'var(--warning)';
        
        updateAuctionBids();
        
        // Notificar
        addLog(`🔨 ${player.name} fez um lance de $${newBid}!`, 'action');
        showNotification('Novo Lance!', `${player.name}: $${newBid}`, 'info');
        soundManager.play('dice');
        
        // IA pode responder automaticamente
        if (getCurrentPlayer().type === 'ai') {
            setTimeout(() => aiConsiderAuctionBid(), 2000);
        }
    }

    function aiConsiderAuctionBid() {
        const player = getCurrentPlayer();
        const difficulty = AI_DIFFICULTY[AI_DIFFICULTY_LEVEL];
        const property = auctionState.property;
        
        // Calcular valor máximo que a IA pagaria
        const maxBid = Math.floor(property.price * (1.2 + difficulty.tradeAggressiveness * 0.3));
        const currentBid = auctionState.currentBid;
        
        // Se o lance atual for menor que o máximo e a IA tiver dinheiro
        if (currentBid < maxBid && player.money > currentBid + 50) {
            // Decidir quanto aumentar
            const bidIncrease = currentBid < property.price * 0.8 ? 50 : 100;
            const shouldBid = Math.random() < (0.8 - difficulty.mistakeChance);
            
            if (shouldBid) {
                makeAuctionBid(bidIncrease);
            }
        }
    }

    function updateAuctionBids() {
        const bidsDiv = document.getElementById('auctionBids');
        
        if (auctionState.bids.length === 0) {
            bidsDiv.innerHTML = '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:20px;">Nenhum lance ainda</div>';
        } else {
            const recentBids = auctionState.bids.slice(-5).reverse();
            bidsDiv.innerHTML = recentBids.map(bid => {
                const player = gameState.players[bid.playerId];
                return `
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 8px;background:var(--bg-card);border-radius:6px;margin-bottom:4px;">
                        <span style="font-size:12px;color:var(--text-primary);">${player.name}</span>
                        <span style="font-size:12px;font-weight:700;color:var(--accent);">$${bid.amount}</span>
                    </div>
                `;
            }).join('');
        }
    }

    function withdrawFromAuction() {
        const player = getCurrentPlayer();
        
        // Se o jogador for o atual lanceiro, permitir retirada
        if (auctionState.currentBidder === player.id) {
            // Encontrar o lance anterior
            let previousBid = null;
            for (let i = auctionState.bids.length - 2; i >= 0; i--) {
                if (auctionState.bids[i].playerId !== player.id) {
                    previousBid = auctionState.bids[i];
                    break;
                }
            }
            
            if (previousBid) {
                auctionState.currentBid = previousBid.amount;
                auctionState.currentBidder = previousBid.playerId;
                addLog(`🔨 ${player.name} retirou seu lance`, 'warning');
                showNotification('Lance Retirado!', `${player.name} saiu do leilão`, 'warning');
            } else {
                // Se não houver lances anteriores, resetar
                auctionState.currentBid = Math.floor(auctionState.property.price * 0.5);
                auctionState.currentBidder = null;
                addLog(`🔨 ${player.name} retirou seu lance`, 'warning');
                showNotification('Lance Retirado!', `${player.name} saiu do leilão`, 'warning');
            }
            
            updateAuctionDialog();
        } else {
            showNotification('Não pode retirar!', 'Você não é o atual lanceiro', 'warning');
        }
    }

    function updateAuctionDialog() {
        document.getElementById('currentBid').textContent = `$${auctionState.currentBid}`;
        updateAuctionBids();
    }

    function endAuction() {
        clearInterval(auctionState.timer);
        auctionState.timer = null;
        
        if (auctionState.currentBidder !== null) {
            // Alguém ganhou o leilão
            const winner = gameState.players[auctionState.currentBidder];
            const property = auctionState.property;
            
            // Transferir propriedade
            winner.money -= auctionState.currentBid;
            winner.properties.push(property.id);
            gameState.propertyOwners[property.id] = winner.id;
            
            addLog(`🔨 ${winner.name} ganhou o leilão de ${property.name} por $${auctionState.currentBid}!`, 'success');
            showNotification('Leilão Encerrado!', `${winner.name} comprou ${property.name} por $${auctionState.currentBid}`, 'success');
            soundManager.play('buy');
        } else {
            // Ninguém ganhou o leilão
            addLog(`🔨 Leilão de ${auctionState.property.name} encerrado sem vendas!`, 'warning');
            showNotification('Leilão Encerrado!', 'Nenhuma venda realizada', 'warning');
            soundManager.play('error');
        }
        
        // Fechar diálogo e resetar estado
        document.getElementById('auctionDialog').classList.remove('show');
        auctionState.active = false;
        auctionState.property = null;
        auctionState.currentBid = 0;
        auctionState.currentBidder = null;
        auctionState.bids = [];
        auctionState.timeLeft = 30;
        
        updateUI();
        SaveManager.autoSave();
    }

