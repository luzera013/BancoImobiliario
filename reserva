    function aiMakeDecisions() {
        const player = getCurrentPlayer();
        
        // Decidir comprar propriedade
        if (gameState.selectedProperty && player.money >= gameState.selectedProperty.price) {
            // IA mais inteligente: considerar fatores
            const shouldBuy = aiShouldBuyProperty(player, gameState.selectedProperty);
            
            if (shouldBuy) {
                setTimeout(() => {
                    confirmBuy();
                    // Após comprar, decidir sobre construção
                    setTimeout(() => aiConsiderBuilding(), 1500);
                }, 1000);
                return;
            } else {
                setTimeout(() => {
                    declineBuy();
                    // Após recusar, considerar construção
                    setTimeout(() => aiConsiderBuilding(), 1000);
                }, 500);
                return;
            }
        }
        
        // Se não há propriedade para decidir, considerar construção
        aiConsiderBuilding();
    }

    function aiShouldBuyProperty(player, property) {
        const difficulty = AI_DIFFICULTY[AI_DIFFICULTY_LEVEL];
        
        // Fatores para decisão de compra
        const moneyRatio = player.money / property.price;
        const propertyCount = player.properties.length;
        const totalProperties = PROPERTIES.filter(p => p.type === 'property').length;
        const propertyRatio = propertyCount / totalProperties;
        
        // Adicionar chance de erro baseada na dificuldade
        if (Math.random() < difficulty.mistakeChance) {
            // Erro: não comprar mesmo sendo bom negócio
            return false;
        }
        
        // Lógica de decisão baseada na dificuldade
        if (moneyRatio > difficulty.buyThreshold) return true;
        if (moneyRatio > (difficulty.buyThreshold + 0.5) && propertyRatio < 0.3) return true;
        if (moneyRatio > (difficulty.buyThreshold + 1) && property.group !== 'darkblue' && property.group !== 'green') return true;
        if (property.price < 150) return true;
        
        // Decisão baseada em probabilidade ajustada pela dificuldade
        const baseChance = AI_DIFFICULTY_LEVEL === 'easy' ? 0.3 : 
                          AI_DIFFICULTY_LEVEL === 'medium' ? 0.4 :
                          AI_DIFFICULTY_LEVEL === 'hard' ? 0.6 : 0.8;
        
        return Math.random() > (1 - baseChance);
    }

    function aiConsiderBuilding() {
        const player = getCurrentPlayer();
        
        // Verificar se pode construir em algum lugar
        let canBuild = false;
        let bestProperty = null;
        let maxPriority = 0;
        
        for (const g in GROUPS) {
            const gp = GROUPS[g];
            const owned = gp.filter(n => {
                const pr = PROPERTIES.find(p => p.name === n);
                return gameState.propertyOwners[pr.id] === player.id;
            });
            
            if (owned.length === gp.length) {
                // Grupo completo, verificar construção
                gp.forEach(n => {
                    const pr = PROPERTIES.find(p => p.name === n);
                    const houses = gameState.propertyHouses[pr.id] || 0;
                    
                    if (houses < 5) {
                        const cost = houses < 4 ? Math.ceil(pr.price * 0.5) : pr.price;
                        const priority = aiCalculateBuildPriority(player, pr, houses, cost);
                        
                        if (priority > maxPriority && player.money >= cost) {
                            maxPriority = priority;
                            bestProperty = pr;
                            canBuild = true;
                        }
                    }
                });
            }
        }
        
        const difficulty = AI_DIFFICULTY[AI_DIFFICULTY_LEVEL];
        if (canBuild && bestProperty && maxPriority > difficulty.buildThreshold) {
            // Construir na melhor propriedade
            setTimeout(() => {
                if (gameState.propertyHouses[bestProperty.id] < 4) {
                    buildHouseOnProperty(bestProperty.id);
                } else {
                    buildHotelOnProperty(bestProperty.id);
                }
                // Após construir, passar turno
                setTimeout(() => aiEndTurn(), 1500);
            }, 1000);
        } else {
            // Não construir, passar turno
            aiEndTurn();
        }
    }

    function aiCalculateBuildPriority(player, property, currentHouses, cost) {
        const difficulty = AI_DIFFICULTY[AI_DIFFICULTY_LEVEL];
        
        const moneyRatio = player.money / cost;
        const houseCount = Object.values(gameState.propertyHouses).reduce((sum, h) => sum + (h < 5 ? h : 0), 0);
        const totalHouseCount = gameState.players.reduce((sum, p) => 
            sum + p.properties.reduce((s, propId) => s + (gameState.propertyHouses[propId] || 0), 0), 0);
        
        let priority = 0;
        
        // Fator dinheiro (ajustado por dificuldade)
        if (moneyRatio > 3) priority += 0.4;
        else if (moneyRatio > 2) priority += 0.3;
        else if (moneyRatio > 1.5) priority += 0.2;
        else if (moneyRatio > 1) priority += 0.1;
        
        // Fator estratégico
        if (currentHouses === 0) priority += 0.3 * difficulty.tradeAggressiveness;
        else if (currentHouses === 3) priority += 0.4 * difficulty.tradeAggressiveness;
        
        // Fator competitivo
        if (houseCount < totalHouseCount * 0.5) priority += 0.2 * difficulty.tradeAggressiveness;
        
        // Fator de propriedade
        if (property.price > 300) priority += 0.1;
        
        // Adicionar erro baseado na dificuldade
        if (Math.random() < difficulty.mistakeChance) {
            priority *= 0.5; // Reduz prioridade pela metade
        }
        
        return Math.min(1, priority);
    }

