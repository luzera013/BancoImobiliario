    function buildHouse() {
        const player = getCurrentPlayer();
        let completedGroups = [];
        for (const g in GROUPS) {
            const gp = GROUPS[g];
            const owned = gp.filter(n => {
                const pr = PROPERTIES.find(p => p.name === n);
                return gameState.propertyOwners[pr.id] === player.id;
            });
            if (owned.length === gp.length) {
                completedGroups.push({ groupName: g, props: gp.map(n => PROPERTIES.find(p => p.name === n)) });
            }
        }
        if (!completedGroups.length) { showNotification('Sem grupos!', 'Você não tem um grupo completo', 'error'); return; }

        let html = '<div style="display:flex;flex-direction:column;gap:8px;max-height:300px;overflow-y:auto;">';
        completedGroups.forEach(group => {
            html += `<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-top:8px;">${group.groupName}</div>`;
            group.props.forEach(prop => {
                const houses = gameState.propertyHouses[prop.id] || 0;
                const costHouse = Math.ceil(prop.price * 0.5);
                const costHotel = prop.price;
                if (houses < 4) {
                    html += `<button onclick="buildHouseOnProperty(${prop.id})" style="width:100%;padding:10px 14px;background:var(--bg-card2);border:1px solid var(--border);border-left:3px solid #22c55e;border-radius:var(--radius-sm);cursor:pointer;text-align:left;color:var(--text-primary);font-size:12px;font-weight:600;font-family:inherit;display:flex;justify-content:space-between;align-items:center;">
                        <span>${prop.name} (${houses} 🏠)</span>
                        <span style="color:#4ade80;font-weight:700;">-$${costHouse}</span>
                    </button>`;
                } else if (houses === 4) {
                    html += `<button onclick="buildHotelOnProperty(${prop.id})" style="width:100%;padding:10px 14px;background:var(--bg-card2);border:1px solid var(--border);border-left:3px solid #ef4444;border-radius:var(--radius-sm);cursor:pointer;text-align:left;color:var(--text-primary);font-size:12px;font-weight:600;font-family:inherit;display:flex;justify-content:space-between;align-items:center;">
                        <span>${prop.name} -> 🏨 Hotel</span>
                        <span style="color:#f87171;font-weight:700;">-$${costHotel}</span>
                    </button>`;
                } else {
                    html += `<div style="width:100%;padding:10px 14px;background:var(--bg-card2);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:12px;color:var(--text-muted);">
                        ${prop.name} <span style="color:#f87171;">🏨 Hotel completo</span>
                    </div>`;
                }
            });
        });
        html += '</div>';

        document.getElementById('buildDialogContent').innerHTML = html;
        document.getElementById('buildDialog').classList.add('show');
    }

    function buildHouseOnProperty(propId) {
        const player = getCurrentPlayer();
        const property = PROPERTIES[propId];
        const cost = Math.ceil(property.price * 0.5);
        const houses = gameState.propertyHouses[propId] || 0;
        if (houses >= 4) { showNotification('Limite!', 'Já tem 4 casas. Construa um hotel!', 'error'); return; }
        if (player.money < cost) { showNotification('Saldo insuficiente!', `Precisa de $${cost}`, 'error'); return; }
        player.money -= cost;
        gameState.propertyHouses[propId] = houses + 1;
        gameState.stats.totalMoneySpent += cost;
        gameState.stats.housesBuilt++;
        soundManager.play('build');
        addLog(`${player.name} construiu uma casa em ${property.name} (-$${cost})`, 'action');
        showNotification('Casa construída!', `${property.name} - $${cost}`, 'success');
        document.getElementById('buildDialog').classList.remove('show');
        updateUI();
    }

    function buildHotelOnProperty(propId) {
        const player = getCurrentPlayer();
        const property = PROPERTIES[propId];
        const cost = property.price;
        const houses = gameState.propertyHouses[propId] || 0;
        if (houses !== 4) { showNotification('Precisa de 4 casas!', 'Construa mais casas primeiro', 'error'); return; }
        if (player.money < cost) { showNotification('Saldo insuficiente!', `Precisa de $${cost}`, 'error'); return; }
        player.money -= cost;
        gameState.propertyHouses[propId] = 5;
        gameState.stats.totalMoneySpent += cost;
        gameState.stats.hotelsBuilt++;
        soundManager.play('build');
        addLog(`${player.name} construiu um hotel em ${property.name} (-$${cost})`, 'action');
        showNotification('Hotel construído!', `${property.name} - $${cost}`, 'success');
        document.getElementById('buildDialog').classList.remove('show');
        updateUI();
    }

    function declineBuild() { 
        document.getElementById('buildDialog').classList.remove('show'); 
    }

    function endTurn() {
        gameState.diceValue = 0;
        gameState.dice1 = 0;
        gameState.dice2 = 0;
        gameState.selectedProperty = null;
        
        // Parar timer atual
        stopTurnTimer();
        
        // Processar empréstimos bancários
        processBankLoans();
        
        // Processar eventos econômicos (modo Desafio)
        if (GAME_MODE === 'challenge') {
            processEconomicEvents();
        }
        
        // Próximo jogador
        gameState.currentPlayerIndex = (gameState.currentPlayerIndex + 1) % gameState.players.length;
        
        if (gameState.currentPlayerIndex === 0) {
            gameState.round++;
        }
        
        updateUI();
        
        // Iniciar timer para o próximo jogador
        if (turnTimer.enabled) {
            startTurnTimer();
