    const SaveManager = {
        save: function() {
            // Salvar dados de personalização primeiro
            saveCustomizationData();
            
            const saveData = {
                gameState: gameState,
                playerXP: playerXP,
                playerStats: playerStats,
                globalStats: globalStats,
                virtualEconomy: VIRTUAL_ECONOMY,
                timestamp: Date.now(),
