    function selectGameMode(mode) {
        GAME_MODE = mode;
        const modeConfig = GAME_MODES[mode];
        STARTING_MONEY = modeConfig.startingMoney;
        closeGameModes();
        startGameSetup();
    }

    function startGameSetup() {
        const modeConfig = GAME_MODES[GAME_MODE];
        generatePlayerSetup(modeConfig.playerCount);
        switchScreen('setupScreen');
    }

    function generatePlayerSetup(count) {
        const container = document.getElementById('playersSetup');
        container.innerHTML = '';
        for (let i = 0; i < count; i++) {
            const div = document.createElement('div');
            div.className = `player-setup ${PLAYER_COLORS[i]}`;
            div.innerHTML = `
                <div class="player-number">JOGADOR ${i + 1}</div>
                <input type="text" class="player-input" id="playerName${i}" placeholder="Nome do jogador" value="${PLAYER_NAMES[i]}">
                <div class="player-type-select">
                    <button class="type-btn ${i === 0 ? 'active' : ''}" onclick="setPlayerType(${i}, 'human')" id="type-human-${i}">Humano</button>
                    <button class="type-btn ${i > 0 ? 'active' : ''}" onclick="setPlayerType(${i}, 'ai')" id="type-ai-${i}">IA</button>
                </div>
            `;
            container.appendChild(div);
        }
    }

    function setPlayerType(index, type) {
        document.getElementById(`type-human-${index}`).classList.toggle('active', type === 'human');
        document.getElementById(`type-ai-${index}`).classList.toggle('active', type === 'ai');
    }

    function startGame() {
        const modeConfig = GAME_MODES[GAME_MODE];
        gameState.players = [];
        
        for (let i = 0; i < modeConfig.playerCount; i++) {
            const nameInput = document.getElementById(`playerName${i}`);
            const name = nameInput ? nameInput.value : PLAYER_NAMES[i];
            const typeBtn = document.querySelector(`.player-setup:nth-child(${i + 1}) .type-btn.active`);
            const isAI = typeBtn && typeBtn.textContent.includes('IA');
            
            gameState.players.push({
                id: i,
                name: name || PLAYER_NAMES[i],
                money: modeConfig.startingMoney,
                properties: [],
                position: 0,
                inJail: false,
                jailTurns: 0,
                type: isAI ? 'ai' : 'human'
            });
        }
        
        gameState.currentPlayerIndex = 0;
        gameState.round = 1;
        gameState.started = true;
        gameState.gameActive = true;
        gameState.propertyOwners = {};
        gameState.propertyHouses = {};
        gameState.gameLog = [];
        gameState.diceValue = 0;
        gameState.dice1 = 0;
        gameState.dice2 = 0;
        
        switchScreen('gameScreen');
        updateUI();
        addLog(`Partida iniciada - Modo: ${modeConfig.name}`, 'success');
        
        if (getCurrentPlayer().type === 'ai') {
            setTimeout(rollDice, 1800);
        }
    }

    function showNotification(title, message, type = 'info') {
        const container = document.querySelector('.notification-container') || createNotificationContainer();
        const notification = document.createElement('div');
        notification.className = `notification ${type}`;
        
        const icons = {
            success: '✅',
            warning: '⚠️',
            error: '❌',
            info: 'ℹ️'
        };
        
        notification.innerHTML = `
            <span class="notif-icon">${icons[type]}</span>
            <div class="notif-body">
                <div class="notif-title">${title}</div>
                <div class="notif-msg">${message}</div>
            </div>
        `;
        
        container.appendChild(notification);
        
        setTimeout(() => {
            notification.classList.add('hide');
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    function createNotificationContainer() {
        const container = document.createElement('div');
        container.className = 'notification-container';
        document.body.appendChild(container);
        return container;
    }

    function addLog(message, type = 'info') {
        const log = document.getElementById('gameLog');
        const entry = document.createElement('div');
        entry.className = `log-entry ${type}`;
        
        const icons = {
            action: '✅',
            warning: '⚠️',
            error: '❌',
            info: 'ℹ️'
        };
        
        entry.innerHTML = `
            <span class="log-icon">${icons[type]}</span>
            <span class="log-text">${message}</span>
        `;
        
        log.insertBefore(entry, log.firstChild);
        
        // Manter apenas os últimos 20 logs
        while (log.children.length > 20) {
            log.removeChild(log.lastChild);
        }
    }

