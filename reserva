    function mortgageProperty(propId) {
        const player = getCurrentPlayer();
        const prop = PROPERTIES[propId];
        const mortgageAmount = Math.floor(prop.price * 0.5);
        
        // Verificar se pode hipotecar
        if (mortgageState.mortgagedProperties[propId]) {
            showNotification('Propriedade já hipotecada!', 'Esta propriedade já está hipotecada', 'error');
            return;
        }
        
        if ((gameState.propertyHouses[propId] || 0) > 0) {
            showNotification('Não pode hipotecar!', 'Remova todas as casas antes de hipotecar', 'error');
            return;
        }
        
        // Executar hipoteca
        player.money += mortgageAmount;
        mortgageState.mortgagedProperties[propId] = {
            playerId: player.id,
            mortgageAmount: mortgageAmount,
            originalPrice: prop.price
        };
        
        addLog(`🏦 ${player.name} hipotecou ${prop.name} por $${mortgageAmount}`, 'action');
        showNotification('Propriedade Hipotecada!', `${prop.name} - $${mortgageAmount}`, 'success');
        soundManager.play('moneyGain');
        
        showMortgageDialog(); // Atualizar diálogo
        updateUI();
        SaveManager.autoSave();
    }

    function unmortgageProperty(propId) {
        const player = getCurrentPlayer();
        const prop = PROPERTIES[propId];
        const mortgage = mortgageState.mortgagedProperties[propId];
        const repayAmount = Math.floor(mortgage.mortgageAmount * 1.1); // 10% de juros
        
        // Verificar se tem dinheiro suficiente
        if (player.money < repayAmount) {
            showNotification('Saldo insuficiente!', `Você precisa de $${repayAmount} para pagar a hipoteca`, 'error');
            return;
        }
        
        // Executar pagamento
        player.money -= repayAmount;
        delete mortgageState.mortgagedProperties[propId];
        
        addLog(`🏦 ${player.name} pagou a hipoteca de ${prop.name} por $${repayAmount}`, 'action');
        showNotification('Hipoteca Paga!', `${prop.name} - $${repayAmount}`, 'success');
        soundManager.play('moneyLoss');
        
        showMortgageDialog(); // Atualizar diálogo
        updateUI();
        SaveManager.autoSave();
    }

