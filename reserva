    // Sistema de Timer de Turnos
    function startTurnTimer() {
        if (!turnTimer.enabled) return;
        
        // Limpar timer anterior
        if (turnTimer.timer) {
            clearInterval(turnTimer.timer);
        }
        
        // Resetar timer
        turnTimer.timeLeft = turnTimer.duration;
        updateTimerDisplay();
        
        // Iniciar countdown
        turnTimer.timer = setInterval(() => {
            turnTimer.timeLeft--;
            updateTimerDisplay();
            
            // Verificar se o tempo acabou
            if (turnTimer.timeLeft <= 0) {
                endTurn(); // Passar automaticamente
                stopTurnTimer();
            }
        }, 1000);
    }
    
    function stopTurnTimer() {
        if (turnTimer.timer) {
            clearInterval(turnTimer.timer);
            turnTimer.timer = null;
        }
    }
    
    function updateTimerDisplay() {
        const timerDisplay = document.getElementById('turnTimerDisplay');
        const timerValue = document.getElementById('timerValue');
        const timerProgress = document.getElementById('timerProgress');
        
        if (!turnTimer.enabled) {
            timerDisplay.style.display = 'none';
            return;
        }
        
        timerDisplay.style.display = 'block';
        timerValue.textContent = `${turnTimer.timeLeft}s`;
        
        // Atualizar barra de progresso
        const progress = (turnTimer.timeLeft / turnTimer.duration) * 100;
        timerProgress.style.width = `${progress}%`;
        
        // Mudar cor baseada no tempo restante
        timerValue.classList.remove('warning', 'danger');
        if (turnTimer.timeLeft <= turnTimer.warningThreshold) {
            timerValue.classList.add('danger');
        } else if (turnTimer.timeLeft <= turnTimer.warningThreshold * 2) {
            timerValue.classList.add('warning');
        }
    }
    
    function toggleTimer() {
        const checkbox = document.getElementById('timerToggle');
        turnTimer.enabled = checkbox.checked;
        
        if (turnTimer.enabled && gameState.started) {
            startTurnTimer();
        } else {
            stopTurnTimer();
            updateTimerDisplay();
        }
        
        // Salvar configuração
        localStorage.setItem('bancoImobiliarioTimer', turnTimer.enabled);
    }

    // Sistema de XP e Níveis
    function addXP(playerId, amount, reason) {
        if (!playerXP[playerId]) return;
        
        const player = gameState.players[playerId];
        const oldLevel = playerXP[playerId].level;
        
        playerXP[playerId].xp += amount;
        playerXP[playerId].totalXP += amount;
        
        // Verificar se subiu de nível
        const newLevel = calculateLevel(playerXP[playerId].totalXP);
        if (newLevel > oldLevel) {
            levelUp(playerId, oldLevel, newLevel);
        }
        
        // Atualizar display
        updateXPDisplay(playerId);
        
        // Notificar
        addLog(`⭐ ${player.name} ganhou ${amount} XP - ${reason}`, 'success');
    }
    
    function calculateLevel(totalXP) {
        for (let i = LEVEL_THRESHOLDS.length - 1; i >= 0; i--) {
            if (totalXP >= LEVEL_THRESHOLDS[i].xp) {
                return LEVEL_THRESHOLDS[i].level;
            }
        }
        return 1;
    }
    
    function getLevelInfo(level) {
        return LEVEL_THRESHOLDS.find(l => l.level === level) || LEVEL_THRESHOLDS[0];
    }
    
    function levelUp(playerId, oldLevel, newLevel) {
        const player = gameState.players[playerId];
        const levelInfo = getLevelInfo(newLevel);
        
        playerXP[playerId].level = newLevel;
        
        // Bônus por subir de nível
        const bonus = newLevel * 100;
        player.money += bonus;
        
        addLog(`🎉 ${player.name} subiu para o nível ${newLevel} - ${levelInfo.title}! Ganhou $${bonus} de bônus!`, 'success');
        showNotification('Level Up!', `${player.name} agora é ${levelInfo.title}!`, 'success');
        soundManager.play('achievement');
    }
    
    function updateXPDisplay(playerId) {
        const player = gameState.players[playerId];
        const xpData = playerXP[playerId];
        const levelInfo = getLevelInfo(xpData.level);
        const nextLevel = getLevelInfo(xpData.level + 1);
        
        // Calcular progresso para o próximo nível
        const currentLevelXP = levelInfo.xp;
        const nextLevelXP = nextLevel ? nextLevel.xp : currentLevelXP + 1000;
        const progress = ((xpData.totalXP - currentLevelXP) / (nextLevelXP - currentLevelXP)) * 100;
        
        // Atualizar display se for o jogador atual
        if (playerId === gameState.currentPlayerIndex) {
            const xpBar = document.querySelector('.xp-bar');
            const xpProgress = document.querySelector('.xp-progress');
            const levelBadge = document.querySelector('.level-badge');
            
            if (xpBar && xpProgress) {
                xpBar.style.display = 'block';
                xpProgress.style.width = `${Math.min(progress, 100)}%`;
            }
            
            if (levelBadge) {
                levelBadge.textContent = `Nível ${xpData.level}`;
                levelBadge.style.display = 'inline-block';
            }
        }
    }
    
    function initializeXP() {
        gameState.players.forEach((player, index) => {
            if (!playerXP[index]) {
                playerXP[index] = { xp: 0, level: 1, totalXP: 0 };
            }
            if (!playerStats[index]) {
                playerStats[index] = { trades: 0, auctionsWon: 0, eventsSurvived: 0, luckyStreak: 0, bankruptRecoveries: 0 };
            }
        });
    }
    
    // Funções auxiliares para conquistas
    function checkMonopoly(player) {
        const colorGroups = {};
        player.properties.forEach(propId => {
            const prop = PROPERTIES[propId];
            if (prop && prop.group) {
                if (!colorGroups[prop.group]) colorGroups[prop.group] = [];
                colorGroups[prop.group].push(propId);
            }
        });
        
        // Verificar se algum grupo está completo
        for (const group in GROUPS) {
            const groupProps = GROUPS[group];
            const ownedProps = colorGroups[group] || [];
            if (ownedProps.length === groupProps.length) {
                return true;
            }
        }
        return false;
    }
    
    function checkHousesCount(player) {
        let count = 0;
        player.properties.forEach(propId => {
            const houses = gameState.propertyHouses[propId] || 0;
            if (houses > 0 && houses < 5) count += houses;
        });
        return count;
    }
    
    function checkHotelsCount(player) {
        let count = 0;
        player.properties.forEach(propId => {
            if (gameState.propertyHouses[propId] >= 5) count++;
